<Window
    x:Class="AudioRepeator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AudioRepeator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance Type={x:Type local:MainWindowViewModel}}"
    mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  频率阈值设置  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <TextBlock
                Width="100"
                VerticalAlignment="Center"
                Text="频率阈值(Hz)：" />
            <TextBox
                x:Name="txtFrequencyThreshold"
                Width="100"
                Margin="5,0"
                Text="1000" />
            <Button
                x:Name="btnStart"
                Width="100"
                Margin="10,0"
                Click="BtnStart_Click"
                Content="开始监测" />
            <Button
                x:Name="btnStop"
                Width="100"
                Margin="5,0"
                Click="BtnStop_Click"
                Content="停止监测"
                IsEnabled="False" />
        </StackPanel>

        <!--  实时数据显示  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <TextBlock
                Width="120"
                VerticalAlignment="Center"
                Text="当前检测频率：" />
            <TextBlock
                x:Name="txtCurrentFrequency"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="0 Hz" />
        </StackPanel>

        <!--  触发次数显示  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <TextBlock
                Width="120"
                VerticalAlignment="Center"
                Text="总触发次数：" />
            <TextBlock
                x:Name="txtTotalCount"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="0" />
            <TextBlock
                Width="120"
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                Text="5秒内触发次数：" />
            <TextBlock
                x:Name="txt5sCount"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Foreground="Blue"
                Text="0" />
        </StackPanel>

        <!--  状态提示  -->
        <StackPanel
            Grid.Row="3"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <TextBlock
                Width="120"
                VerticalAlignment="Center"
                Text="当前状态：" />
            <TextBlock
                x:Name="txtStatus"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Foreground="Gray"
                Text="未监测" />
        </StackPanel>

        <!--  播放提示  -->
        <StackPanel
            Grid.Row="4"
            Margin="0,0,0,10"
            Orientation="Horizontal">
            <TextBlock
                x:Name="txtPlaybackTip"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Foreground="Red"
                Text="" />
        </StackPanel>

        <!--  音频波形展示区域  -->
        <Border
            Grid.Row="5"
            Margin="0,10,0,0"
            BorderBrush="LightGray"
            BorderThickness="1">
            <Canvas x:Name="waveformCanvas" Background="#F8F8F8" />
        </Border>
    </Grid>
</Window>
